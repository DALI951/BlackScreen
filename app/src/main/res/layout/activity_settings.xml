<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/surface">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/surface"
        android:title="@string/settings_title"
        android:titleTextColor="@color/white"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AOD Elements"
                android:textSize="14sp"
                android:textColor="@color/accent"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchClock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/pref_show_clock"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:checked="true"
                android:layout_marginBottom="12dp"
                android:minHeight="48dp"
                android:padding="8dp"/>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/pref_show_date"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:checked="true"
                android:layout_marginBottom="12dp"
                android:minHeight="48dp"
                android:padding="8dp"/>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchBattery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/pref_show_battery"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:checked="true"
                android:layout_marginBottom="12dp"
                android:minHeight="48dp"
                android:padding="8dp"/>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchMedia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/pref_show_media"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:checked="true"
                android:layout_marginBottom="24dp"
                android:minHeight="48dp"
                android:padding="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Timing"
                android:textSize="14sp"
                android:textColor="@color/accent"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pref_aod_timeout"
                android:textColor="@color/white"
                android:textSize="16sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pref_aod_timeout_summary"
                android:textColor="@color/gray"
                android:textSize="12sp"
                android:layout_marginBottom="8dp"/>

            <Spinner
                android:id="@+id/spinnerTimeout"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_card"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="About"
                android:textSize="14sp"
                android:textColor="@color/accent"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="BlackScreen v0.3.0\n\nOLED black screen overlay with configurable Always-On Display.\n\nAccessibility services can click through the black overlay."
                android:textColor="@color/light_gray"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.3"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
